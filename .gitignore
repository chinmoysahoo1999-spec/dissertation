# Large data files — never commit these
Code/hallucination_10k.json
Code/*.json
Code/*.pth

# Per-model intermediate artefacts in subdirectories — must use ** glob
# (otherwise Code/*.json only matches direct children of Code/, not files
# inside Code/project_*/ which is where the large feature caches live)
Code/**/*_baseline_feature_cache.json   # ~150 MB, regenerated by Stage 2 of baselines_sota.ipynb
Code/**/*_dataset_full.json              # ~12 MB per model, regenerated by Stage 2 of all_variants.ipynb
Code/**/*_dataset_with_features.json     # ~13 MB per model, regenerated by Stage 3
Code/**/*_datagen_checkpoint.json        # incremental save during data-gen
Code/**/*_train.json                     # train split JSON, derivable from dataset_full
Code/**/*_test.json                      # test split JSON, derivable from dataset_full
Code/**/*.pth                            # all MLP / probe checkpoints in subdirs
Code/**/*_dataset_with_F157.json         # variant_F augmented dataset (deprecated)

# But DO track the result files (small) AND the small preview
!Code/preview.json
!Code/**/*_results.json                  # all_variants_results.json, baselines_results.json (small, key audit)
!Code/**/*_all_variants_results.json
!Code/**/*_baselines_results.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Virtual environments
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db
desktop.ini

